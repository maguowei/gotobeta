### 健康检查

# @name healthCheck
GET {{baseUrl}}/health
Accept: application/json

> {%
  client.test("healthCheck 返回 HTTP 200", () => {
    client.assert(response.status === 200, `期望 200，实际 ${response.status}`);
  });
  client.test("healthCheck status=ok", () => {
    client.assert(response.body.status === "ok", `期望 status=ok，实际 ${response.body.status}`);
  });
%}

